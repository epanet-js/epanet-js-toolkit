{
    "name": "@epanet-js/epanet-engine",
    "version": "1.0.1",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build:image": "./scripts/build-docker-image.sh",
        "build:docker": "docker run --rm -v \"$PWD\"/dist:/opt/epanet/dist epanet-js-engine npm run build:local",
        "build:local": "./scripts/build.sh && rollup -c",
        "build": "npm run build:image && npm run build:docker",
        "test": "vitest run",
        "prepublishOnly": "npm run build",
        "publish:local": "npm run clean && npm run build && npm pack",
        "clean": "rm -rf build dist lib"
    },
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        },
