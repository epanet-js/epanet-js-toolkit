{
  "name": "epanet-engine",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "./scripts/build.sh && rollup -c && cp src/index.d.ts dist/index.d.ts && cp -r lib/. dist/",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf build dist lib"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./v2.2":       { "import": "./dist/v2.2/EpanetEngine.js",       "types": "./dist/v2.2/types/index.d.ts" },
    "./v2.2-msx":   { "import": "./dist/v2.2-msx/EpanetEngine.js",   "types": "./dist/v2.2-msx/types/index.d.ts" },
    "./v2.3":       { "import": "./dist/v2.3/EpanetEngine.js",       "types": "./dist/v2.3/types/index.d.ts" },
    "./v2.3-msx":   { "import": "./dist/v2.3-msx/EpanetEngine.js",   "types": "./dist/v2.3-msx/types/index.d.ts" },
    "./v2.3.1":     { "import": "./dist/v2.3.1/EpanetEngine.js",     "types": "./dist/v2.3.1/types/index.d.ts" },
    "./v2.3.1-msx": { "import": "./dist/v2.3.1-msx/EpanetEngine.js", "types": "./dist/v2.3.1-msx/types/index.d.ts" },
    "./v2.3.2":     { "import": "./dist/v2.3.2/EpanetEngine.js",     "types": "./dist/v2.3.2/types/index.d.ts" },
    "./v2.3.2-msx": { "import": "./dist/v2.3.2-msx/EpanetEngine.js", "types": "./dist/v2.3.2-msx/types/index.d.ts" },
    "./v2.3.3":     { "import": "./dist/v2.3.3/EpanetEngine.js",     "types": "./dist/v2.3.3/types/index.d.ts" },
    "./v2.3.3-msx": { "import": "./dist/v2.3.3-msx/EpanetEngine.js", "types": "./dist/v2.3.3-msx/types/index.d.ts" },
    "./v2.3.4":     { "import": "./dist/v2.3.4/EpanetEngine.js",     "types": "./dist/v2.3.4/types/index.d.ts" },
    "./v2.3.4-msx": { "import": "./dist/v2.3.4-msx/EpanetEngine.js", "types": "./dist/v2.3.4-msx/types/index.d.ts" },
    "./v2.3.5":     { "import": "./dist/v2.3.5/EpanetEngine.js",     "types": "./dist/v2.3.5/types/index.d.ts" },
    "./v2.3.5-msx": { "import": "./dist/v2.3.5-msx/EpanetEngine.js", "types": "./dist/v2.3.5-msx/types/index.d.ts" },
    "./master":     { "import": "./dist/master/EpanetEngine.js",     "types": "./dist/master/types/index.d.ts" },
    "./master-msx": { "import": "./dist/master-msx/EpanetEngine.js", "types": "./dist/master-msx/types/index.d.ts" },
    "./dev":        { "import": "./dist/dev/EpanetEngine.js",        "types": "./dist/dev/types/index.d.ts" },
    "./dev-msx":    { "import": "./dist/dev-msx/EpanetEngine.js",    "types": "./dist/dev-msx/types/index.d.ts" }
  },
  "devDependencies": {
    "rollup": "^4.0.0",
    "vitest": "^3.0.0"
  }
}
